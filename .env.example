# =============================================================================
# Yubi — environment variables used by docker-compose.yml
# =============================================================================
# Copy to `.env` and edit as needed. `.env` is gitignored.
#
# Per-host secrets (API key, backend URL, credentials) live in
# `yubi_bringup/config/local/<file>.yaml` — that directory is gitignored and
# is merged on top of common/ and <variant>/ when build-config runs.
# =============================================================================

# ROS
# ROS_DISTRO selects the ROS 2 distribution used to build the images
# (yubi:latest is built on top of yubi-core:latest). Options: jazzy (default), humble.
ROS_DISTRO=jazzy
ROS_DOMAIN_ID=0
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# Robot variant selects which config overlay (config/<variant>/) is merged on
# top of config/common/ to produce config/_runtime/<variant>/.
# Options: stationary (yagura, RealSense head cam, footpedal),
#          portable (USB center cam, Quest controller buttons).
ROBOT_VARIANT=stationary

# Data Storage
DATA_MOUNT_PATH=${HOME}/yubi_data

# MinIO (local S3 for recording uploads)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_DATA_PATH=./minio_data

# Web Video Server
WEB_VIDEO_SERVER_PORT=9091

# Sentry error tracking (optional)
SENTRY_DSN=

# Display (for GUI apps)
DISPLAY=:0
