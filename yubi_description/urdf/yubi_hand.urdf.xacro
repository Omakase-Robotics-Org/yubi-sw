<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="yubi_hands">
  <xacro:property name="palm_size" value="0.044 0.067 0.0735"/>
  <xacro:property name="finger_mesh_dir" value="package://yubi_description/meshes"/>
  <xacro:property name="finger_lower_limit" value="0.00"/>
  <xacro:property name="finger_upper_limit" value="0.94"/>
  <xacro:property name="finger_offset_y" value="0.015"/>
  <xacro:property name="finger_tip_offset_y" value="-0.014"/>
  <xacro:property name="finger_tip_offset_x" value="0.10943"/>

  <material name="yubi_gray">
    <color rgba="1.0 1.0 1.0 1"/>
  </material>

  <xacro:macro name="yubi_hand" params="hand_prefix">
    <link name="${hand_prefix}_hand_root">
      <visual>
        <origin xyz="-0.022 0 -0.02015" rpy="0 0 0"/>
        <geometry>
          <box size="${palm_size}"/>
        </geometry>
        <material name="yubi_gray"/>
      </visual>
      <collision>
        <origin xyz="-0.022 0 -0.02015" rpy="0 0 0"/>
        <geometry>
          <box size="${palm_size}"/>
        </geometry>
      </collision>
    </link>

    <joint name="${hand_prefix}_camera_joint" type="fixed">
      <origin xyz="0 0 0.0426" rpy="0 0 0"/>
      <parent link="${hand_prefix}_hand_root"/>
      <child link="${hand_prefix}_hand_cam_link"/>
    </joint>

    <link name="${hand_prefix}_hand_cam_link">
      <visual>
        <origin xyz="-0.0175 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.035 0.032 0.042"/>
        </geometry>
        <material name="yubi_gray"/>
      </visual>
      <collision>
        <origin xyz="-0.0175 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.035 0.032 0.042"/>
        </geometry>
      </collision>
    </link>

    <!-- Primary finger (driven directly by encoder) -->
    <joint name="${hand_prefix}_right_finger_joint" type="revolute">
      <origin xyz="-0.016 ${-finger_offset_y} 0" rpy="0 0 0"/>
      <parent link="${hand_prefix}_hand_root"/>
      <child link="${hand_prefix}_right_finger_link"/>
      <axis xyz="0 0 -1"/>
      <limit lower="${finger_lower_limit}" upper="${finger_upper_limit}" effort="5" velocity="2"/>
    </joint>

    <link name="${hand_prefix}_right_finger_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${finger_mesh_dir}/hand_${hand_prefix}_right_finger_link.STL"/>
        </geometry>
        <material name="yubi_gray"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${finger_mesh_dir}/hand_${hand_prefix}_right_finger_link_col.STL"/>
        </geometry>
      </collision>
    </link>

    <joint name="${hand_prefix}_right_finger_tip_joint" type="fixed">
      <origin xyz="${finger_tip_offset_x} ${finger_tip_offset_y} 0" rpy="0 0 0"/>
      <parent link="${hand_prefix}_right_finger_link"/>
      <child link="${hand_prefix}_right_finger_tip_link"/>
    </joint>

    <link name="${hand_prefix}_right_finger_tip_link">
    </link>

    <!-- Mirror finger (mimic joint, inverse motion) -->
    <joint name="${hand_prefix}_left_finger_joint" type="revolute">
      <origin xyz="-0.016 ${finger_offset_y} 0" rpy="0 0 0"/>
      <parent link="${hand_prefix}_hand_root"/>
      <child link="${hand_prefix}_left_finger_link"/>
      <axis xyz="0 0 -1"/>
      <limit lower="${-finger_upper_limit}" upper="${-finger_lower_limit}" effort="5" velocity="2"/>
      <mimic joint="${hand_prefix}_right_finger_joint" multiplier="-1" offset="0"/>
    </joint>

    <link name="${hand_prefix}_left_finger_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${finger_mesh_dir}/hand_${hand_prefix}_left_finger_link.STL"/>
        </geometry>
        <material name="yubi_gray"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${finger_mesh_dir}/hand_${hand_prefix}_left_finger_link_col.STL"/>
        </geometry>
      </collision>
    </link>

    <joint name="${hand_prefix}_left_finger_tip_joint" type="fixed">
      <origin xyz="${finger_tip_offset_x} ${-finger_tip_offset_y} 0" rpy="0 0 0"/>
      <parent link="${hand_prefix}_left_finger_link"/>
      <child link="${hand_prefix}_left_finger_tip_link"/>
    </joint>

    <link name="${hand_prefix}_left_finger_tip_link">
    </link>
  </xacro:macro>

  <link name="quest_origin"/>
  <link name="quest_right_controller"/>
  <link name="quest_left_controller"/>

  <xacro:yubi_hand hand_prefix="right"/>
  <xacro:yubi_hand hand_prefix="left"/>

  <joint name="quest_origin_to_left" type="floating">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="quest_origin"/>
    <child link="left_hand_root"/>
  </joint>

  <joint name="quest_origin_to_right" type="floating">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="quest_origin"/>
    <child link="right_hand_root"/>
  </joint>

  <joint name="right_mount_joint" type="fixed">
    <origin xyz="-0.063 -0.016 0.0525"
            rpy="0 ${radians(-45)} ${radians(-45)}"/>
    <parent link="right_hand_root"/>
    <child link="quest_right_controller"/>
  </joint>

  <joint name="left_mount_joint" type="fixed">
    <origin xyz="-0.063 0.016 0.0525"
            rpy="0 ${radians(-45)} ${radians(45)}"/>
    <parent link="left_hand_root"/>
    <child link="quest_left_controller"/>
  </joint>

</robot>
